{
  "name": "@ant-design/react-native-example",
  "version": "5.5.0",
  "description": "Demo app for ant-design mobile RN UI Library",
  "private": true,
  "homepage": ".",
  "main": "./index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "eject": "expo eject",
    "build-web": "EXPO_WEB_OUTPUT=static expo export -p web",
    "deploy": "npm run build-web && gh-pages -d dist --nojekyll",
    "publish": "eas update",
    "prettify": "prettier --write .  --config ./.prettierrc",
    "lint": "expo lint"
  },
  "dependencies": {
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "gh-pages": "^6.3.0",
    "typescript": "~5.9.2",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0"
  }
}
